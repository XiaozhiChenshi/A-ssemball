[sub_resource type="Shader" id="Shader_goal_sphere"]
code = "shader_type spatial;
render_mode unshaded, cull_back, depth_draw_opaque;

uniform vec4 base_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float brightness = 1.15;
uniform float pulse_speed = 0.25;
uniform float pulse_amp = 0.08;

void fragment() {
	float pulse = 1.0 + sin(TIME * TAU * pulse_speed) * pulse_amp;
	vec3 col = base_color.rgb * brightness * pulse;
	ALBEDO = clamp(col, vec3(0.0), vec3(1.0));
	ALPHA = base_color.a;
}
"

