[sub_resource type="Shader" id="Shader_goal_sphere"]
code = "shader_type spatial;
render_mode cull_back, depth_draw_opaque;

uniform vec4 base_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float roughness = 0.35;
uniform float specular_strength = 0.22;
uniform float fresnel_strength = 0.07;

void fragment() {
	float fresnel = pow(1.0 - clamp(dot(normalize(NORMAL), normalize(VIEW)), 0.0, 1.0), 2.2);
	vec3 col = base_color.rgb + vec3(fresnel * fresnel_strength);
	ALBEDO = clamp(col, vec3(0.0), vec3(1.0));
	ROUGHNESS = roughness;
	SPECULAR = specular_strength;
	ALPHA = base_color.a;
}
"

