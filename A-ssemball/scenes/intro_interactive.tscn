[sub_resource type="Shader" id="Shader_grid_static"]
code = "shader_type spatial;
render_mode cull_disabled, depth_draw_opaque;

uniform vec4 color_a : source_color = vec4(0.18, 0.22, 0.26, 1.0);
uniform vec4 color_b : source_color = vec4(0.13, 0.16, 0.20, 1.0);
uniform vec4 line_color : source_color = vec4(0.41, 0.47, 0.55, 1.0);
uniform float grid_repeat = 40.0;
uniform float line_width = 0.045;
uniform float roughness = 0.92;
uniform float specular_strength = 0.05;
uniform float gradient_strength = 0.4;
uniform float gradient_front_brightness = 0.8;
uniform float gradient_back_brightness = 1.12;
uniform float gradient_side_darkening = 0.12;

void fragment() {
	vec2 uv = UV * grid_repeat;
	vec2 f = fract(uv);
	float line = step(f.x, line_width) + step(1.0 - f.x, line_width) + step(f.y, line_width) + step(1.0 - f.y, line_width);
	line = clamp(line, 0.0, 1.0);
	float checker = mod(floor(uv.x) + floor(uv.y), 2.0);
	vec3 fill_col = mix(color_a.rgb, color_b.rgb, checker);
	vec3 base_col = mix(fill_col, line_color.rgb, line);
	float depth_grad = mix(gradient_front_brightness, gradient_back_brightness, smoothstep(0.0, 1.0, UV.y));
	float side_grad = 1.0 - abs(UV.x - 0.5) * 2.0 * gradient_side_darkening;
	float grad_mix = mix(1.0, depth_grad * side_grad, clamp(gradient_strength, 0.0, 1.0));
	ALBEDO = base_col * grad_mix;
	ROUGHNESS = roughness;
	SPECULAR = specular_strength;
	ALPHA = 1.0;
}
"

