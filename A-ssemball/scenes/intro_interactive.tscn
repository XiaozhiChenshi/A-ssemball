[sub_resource type="Shader" id="Shader_moire_noise_overlay"]
code = "shader_type canvas_item;
render_mode unshaded;

uniform sampler2D screen_tex : hint_screen_texture, repeat_disable, filter_linear_mipmap;
uniform float effect_strength : hint_range(0.0, 1.0) = 0.82;
uniform float noise_strength : hint_range(0.0, 0.6) = 0.16;
uniform float noise_speed : hint_range(0.0, 12.0) = 2.1;
uniform float noise_density : hint_range(120.0, 2200.0) = 1250.0;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
}

void fragment() {
	vec2 uv = SCREEN_UV;
	float t = TIME;
	vec4 base_col = texture(screen_tex, uv);
	vec2 noise_grid = floor(uv * vec2(noise_density, noise_density * 0.5625));
	float noise = hash(noise_grid + vec2(t * noise_speed * 61.0, t * noise_speed * 37.0));
	float noise_signed = (noise - 0.5) * 2.0;
	base_col.rgb += noise_signed * noise_strength * effect_strength;

	COLOR = vec4(clamp(base_col.rgb, vec3(0.0), vec3(1.0)), 1.0);
}
"

