[sub_resource type="Shader" id="Shader_vignette_overlay"]
code = "shader_type canvas_item;

uniform float radius : hint_range(0.0, 1.2) = 0.72;
uniform float softness : hint_range(0.001, 1.0) = 0.38;
uniform float intensity : hint_range(0.0, 1.0) = 0.62;
uniform vec4 vignette_color : source_color = vec4(0.0, 0.0, 0.0, 1.0);

void fragment() {
	vec2 centered = UV - vec2(0.5);
	centered.x *= SCREEN_PIXEL_SIZE.y / SCREEN_PIXEL_SIZE.x;
	float dist = length(centered);
	float edge = smoothstep(radius, radius + softness, dist);
	float alpha = edge * intensity;
	COLOR = vec4(vignette_color.rgb, alpha);
}
"

